{
  "kind": "collectionType",
  "collectionName": "courses",
  "info": { "singularName": "course", "pluralName": "courses", "displayName": "Course" },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "type": { "type": "string" },
    "duration": { "type": "string" },
    "eligibility": { "type": "text" },
    "affiliation": { "type": "text" },
    "award": { "type": "text" },
    "fee": { "type": "string" },
    "benefits": { "type": "json" },
    "careers": { "type": "json" },
    "curriculum": { "type": "richtext" },
    "brochure": { "type": "media", "multiple": false, "allowedTypes": ["files"] },
    "featuredImage": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "seo": { "type": "component", "repeatable": false, "component": "shared.seo" }
  }
}
